generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicantStatus {
  STUDENT
  APPRENTICE
  INTERN
  EMPLOYEE
  FREELANCER
  OTHER
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  WAITING_GUARANTOR
  WAITING_DOCUMENTS
  APPROVED
  REJECTED
  CANCELED
}

enum GuarantorStatus {
  PENDING
  CONTACTED
  CONFIRMED
  DECLINED
}

enum ProductType {
  LAPTOP
  SMARTPHONE
  TABLET
  ROUTER
}

enum PaymentPlanStatus {
  PENDING
  ACTIVE
  COMPLETED
  LATE
  DEFAULTED
  CANCELED
}

enum InstallmentStatus {
  PENDING
  PAID
  LATE
  DEFAULTED
}

enum CollectionStage {
  NONE
  SOFT_COLLECTION
  ESCALATED
  RESOLVED
}

enum ContactStatus {
  NOT_CONTACTED
  CONTACT_ATTEMPTED
  REACHED
  NO_RESPONSE
  PROMISE_TO_PAY
  DISPUTE
  REFUSED
  RESOLVED
}

enum NextActionType {
  CALL
  WHATSAPP
  SMS
  EMAIL
  FOLLOW_UP
  ESCALATE
  NONE
}

enum CollectionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CollectionResolutionStatus {
  OPEN
  MONITORING
  CURED
  CLOSED
}

enum CollectionEventType {
  CASE_CREATED
  CONTACT_ATTEMPTED
  CONTACT_MADE
  PROMISE_TO_PAY
  PROMISE_BROKEN
  FOLLOW_UP_SCHEDULED
  STATUS_CHANGED
  ESCALATED
  NOTE_ADDED
  PAYMENT_CONFIRMED
}

enum CollectionChannel {
  PHONE
  WHATSAPP
  SMS
  EMAIL
  IN_PERSON
  SYSTEM
}

enum CollectionOutcome {
  NO_ANSWER
  CALLBACK_REQUESTED
  PAID
  PARTIAL_PAYMENT
  PROMISED
  REFUSED
  INVALID_NUMBER
  DISPUTED
  INFO_UPDATED
  OTHER
}

model Application {
  id                     String             @id @default(cuid())
  firstName              String
  lastName               String
  dateOfBirth            DateTime
  gender                 String?
  phone                  String
  email                  String?
  addressLine            String
  city                   String
  country                String             @default("Senegal")

  applicantStatus        ApplicantStatus
  schoolName             String?
  programName            String?
  studyLevel             String?
  employerName           String?

  estimatedMonthlyIncome Int?
  incomeSource           String?
  hasFamilySupport       Boolean            @default(false)
  familySupportAmount    Int?

  availableDownPayment   Int
  requestedAmount        Int
  approvedAmount         Int?

  status                 ApplicationStatus  @default(SUBMITTED)
  riskScore              Int?
  adminNotes             String?

  identityDocumentUrl    String?
  statusProofUrl         String?
  incomeProofUrl         String?

  productId              String
  guarantorId            String?            @unique

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  product                Product            @relation(fields: [productId], references: [id])
  guarantor              Guarantor?         @relation(fields: [guarantorId], references: [id])
  paymentPlan            PaymentPlan?
  collectionCase         CollectionCase?
  collectionEvents       CollectionEvent[]

  @@index([status])
  @@index([phone])
  @@index([createdAt])
}

model Guarantor {
  id                      String           @id @default(cuid())
  fullName                String
  relationshipToApplicant String
  phone                   String
  email                   String?
  profession              String?
  addressLine             String?
  city                    String?
  supportType             String?
  status                  GuarantorStatus  @default(PENDING)

  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  application             Application?
}

model Product {
  id           String      @id @default(cuid())
  name         String
  type         ProductType
  brand        String?
  model        String?
  priceCents   Int
  currency     String      @default("XOF")
  isActive     Boolean     @default(true)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  applications Application[]

  @@index([type, isActive])
}

model PaymentPlan {
  id                   String            @id @default(cuid())
  applicationId        String            @unique
  totalAmount          Int
  downPaymentAmount    Int
  financedAmount       Int
  numberOfInstallments Int
  status               PaymentPlanStatus @default(PENDING)
  startDate            DateTime?
  endDate              DateTime?

  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  application          Application       @relation(fields: [applicationId], references: [id])
  installments         Installment[]
  collectionCase       CollectionCase?

  @@index([status])
}

model Installment {
  id                String            @id @default(cuid())
  paymentPlanId     String
  installmentNumber Int
  dueDate           DateTime
  amount            Int
  paidAt            DateTime?
  status            InstallmentStatus @default(PENDING)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  paymentPlan       PaymentPlan       @relation(fields: [paymentPlanId], references: [id])
  collectionEvents  CollectionEvent[]

  @@unique([paymentPlanId, installmentNumber])
  @@index([dueDate, status])
}

model CollectionCase {
  id                  String                     @id @default(cuid())
  applicationId       String                     @unique
  paymentPlanId       String?                    @unique
  stage               CollectionStage            @default(NONE)
  contactStatus       ContactStatus              @default(NOT_CONTACTED)
  nextActionDate      DateTime?
  nextActionType      NextActionType             @default(NONE)
  assignedTo          String?
  lastContactedAt     DateTime?
  lastPromiseDate     DateTime?
  lastPromiseAmount   Int?
  brokenPromiseCount  Int                        @default(0)
  priority            CollectionPriority         @default(MEDIUM)
  resolutionStatus    CollectionResolutionStatus @default(OPEN)
  internalNote        String?

  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  application         Application                @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  paymentPlan         PaymentPlan?               @relation(fields: [paymentPlanId], references: [id], onDelete: SetNull)
  events              CollectionEvent[]

  @@index([stage])
  @@index([contactStatus])
  @@index([priority])
  @@index([nextActionDate])
}

model CollectionEvent {
  id               String              @id @default(cuid())
  collectionCaseId String
  applicationId    String
  installmentId    String?
  eventType        CollectionEventType
  channel          CollectionChannel?
  outcome          CollectionOutcome?
  note             String?
  promisedAmount   Int?
  promisedDate     DateTime?
  createdBy        String?

  createdAt        DateTime            @default(now())

  collectionCase   CollectionCase      @relation(fields: [collectionCaseId], references: [id], onDelete: Cascade)
  application      Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  installment      Installment?        @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  @@index([collectionCaseId, createdAt])
  @@index([applicationId, createdAt])
  @@index([installmentId])
}